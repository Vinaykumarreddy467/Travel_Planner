# === AI Travel Planner - API Keys ===
# Copy this file to .env and fill in your keys

# Groq API - Free tier: 14,400 requests/day, no credit card
# Get yours at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenWeatherMap API - Free tier: 1,000,000 calls/month
# Sign up at: https://home.openweathermap.org/users/sign_up
OWM_API_KEY=your_openweathermap_api_key_here

# Google Maps API - Free tier: $200/month credit
# Get at: https://console.cloud.google.com (enable Places API + Geocoding API)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
